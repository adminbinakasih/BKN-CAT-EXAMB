{
  "name": "bkn-cat-browser",
  "version": "1.0.0",
  "description": "BKN CAT - Secure Browser untuk Ujian CAT Enterprise",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac dmg --x64",
    "build-portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "id.sch.binakasihnusantara.bkncat",
    "productName": "BKN CAT",
    "copyright": "© 2025 SMA Unggul Binakasih Nusantara",
    "asar": true,
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.education",
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BKN CAT"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
